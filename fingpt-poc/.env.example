# =================================================================
# FASTAPI SERVER CONFIGURATION
# =================================================================

# The network interface the server will bind to. 
# Use 0.0.0.0 to allow external access (Docker/Production) 
# or 127.0.0.1 for local-only access.
SERVER_HOST=0.0.0.0

# The port number the server will listen on. 
# Default is usually 8000. Use 80 or 443 for standard web traffic.
SERVER_PORT=8000
